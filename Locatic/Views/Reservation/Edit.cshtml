@model Locatic.Models.ViewModels.ReservationFormVM
@{
    ViewData["Title"] = "Modifier une réservation";
    var minDate = DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="rv-shell">
    <div class="rv-page-head">
        <div>
            <div class="rv-eyebrow">Planning</div>
            <h1>Modifier une réservation</h1>
        </div>
        <a class="rv-btn rv-btn-light" asp-action="Index">← Retour</a>
    </div>

    <div class="rv-card rv-card-pad rv-form">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="rv-field">
                <label asp-for="ClientId" class="form-label"></label>
                <select asp-for="ClientId" asp-items="ViewBag.ClientId" class="form-select">
                    <option value="">-- Sélectionner un client --</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <div class="rv-field">
                <label asp-for="CarId" class="form-label"></label>
                <select asp-for="CarId" asp-items="ViewBag.CarId" class="form-select">
                    <option value="">-- Sélectionner une voiture --</option>
                </select>
                <span asp-validation-for="CarId" class="text-danger"></span>
            </div>

            <div class="rv-field">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" class="form-control" type="date" min="@minDate" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="rv-field">
                <label asp-for="EndDate" class="form-label"></label>
                <input asp-for="EndDate" class="form-control" type="date" min="@minDate" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="rv-form-actions">
                <button type="submit" class="rv-btn rv-btn-primary">Enregistrer</button>
                <a asp-action="Index" class="rv-btn rv-btn-light">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
