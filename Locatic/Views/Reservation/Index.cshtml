@model IEnumerable<Locatic.Models.Reservation>

@{
    ViewData["Title"] = "Réservations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Réservations</h1>
    <a asp-action="Create" class="btn btn-primary">+ Ajouter</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Client</th>
            <th>Voiture</th>
            <th>Date de début</th>
            <th>Date de fin</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reservation in Model)
        {
            <tr>
                <td>@reservation.Client.LastName @reservation.Client.FirstName</td>
                <td>@reservation.Car.CarModel.Brand.Name @reservation.Car.CarModel.Name - @reservation.Car.LicensePlate</td>
                <td>@reservation.StartDate.ToString("dd/MM/yyyy")</td>
                <td>@reservation.EndDate.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@reservation.Id" class="btn btn-sm">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@reservation.Id" class="btn btn-sm btn-danger">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>