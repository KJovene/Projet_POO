@model IEnumerable<Locatic.Models.Car>

@{
    ViewData["Title"] = "Voitures";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Voitures</h1>
    <a asp-action="Create" class="btn btn-primary">+ Ajouter</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Plaque</th>
            <th>Modèle</th>
            <th>Marque</th>
            <th>Année</th>
            <th>Carburant</th>
            <th>Places</th>
            <th>Prix/jour</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var car in Model)
        {
            <tr>
                <td>@car.LicensePlate</td>
                <td>@car.CarModel.Name</td>
                <td>@car.CarModel.Brand.Name</td>
                <td>@car.Year</td>
                <td>@car.FuelType</td>
                <td>@car.NumberOfSeats</td>
                <td>@car.DailyPrice.ToString("C")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@car.Id" class="btn btn-sm">Détails</a>
                    <a asp-action="Edit" asp-route-id="@car.Id" class="btn btn-sm">Modifier</a>
                    <a asp-action="Delete" asp-route-id="@car.Id" class="btn btn-sm btn-danger">Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>
