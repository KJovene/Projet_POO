@model Locatic.Models.Car

@{
    ViewData["Title"] = "Supprimer une voiture";
}

<h1>Supprimer une voiture</h1>

<p class="text-danger">Êtes-vous sûr de vouloir supprimer cette voiture ?</p>

<dl class="row">
    <dt class="col-sm-3">Plaque d'immatriculation</dt>
    <dd class="col-sm-9">@Model.LicensePlate</dd>

    <dt class="col-sm-3">Marque / Modèle</dt>
    <dd class="col-sm-9">@Model.CarModel.Brand.Name @Model.CarModel.Name</dd>

    <dt class="col-sm-3">Année</dt>
    <dd class="col-sm-9">@Model.Year</dd>

    <dt class="col-sm-3">Prix par jour</dt>
    <dd class="col-sm-9">@Model.DailyPrice.ToString("C")</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>
