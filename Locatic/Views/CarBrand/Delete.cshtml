@model Locatic.Models.CarBrand
@{
    ViewData["Title"] = "Supprimer une marque";
    var deleteError = ViewData["DeleteError"] as string;
}

<div class="rv-shell">
    <div class="rv-page-head">
        <div>
            <div class="rv-eyebrow">Centre de contrôle</div>
            <h1>Supprimer une marque</h1>
        </div>
        <a class="rv-btn rv-btn-light" asp-action="Index">← Retour</a>
    </div>

    <div class="rv-card rv-card-pad" style="max-width:680px">
        @if (!string.IsNullOrWhiteSpace(deleteError))
        {
            <div class="rv-alert rv-alert-danger">@deleteError</div>
        }
        else
        {
            <div class="rv-alert rv-alert-danger">
                ⚠️ Êtes-vous sûr de vouloir supprimer cette marque ? Cette action est définitive.
            </div>
        }

        <dl class="rv-dl">
            <dt>Marque</dt>
            <dd>@Model.Name</dd>

            <dt>Pays</dt>
            <dd>@Model.Country</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="rv-form-actions">
                <button type="submit" class="rv-btn rv-btn-danger">Supprimer définitivement</button>
                <a asp-action="Index" class="rv-btn rv-btn-light">Annuler</a>
            </div>
        </form>
    </div>
</div>
