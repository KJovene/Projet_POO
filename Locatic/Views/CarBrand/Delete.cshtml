@model Locatic.Models.CarBrand

@{
    ViewData["Title"] = "Supprimer une marque";
    var deleteError = ViewData["DeleteError"] as string;
}

<h1>Supprimer une marque</h1>

@if (!string.IsNullOrWhiteSpace(deleteError))
{
    <div class="alert alert-danger">@deleteError</div>
}

<p class="text-danger">Êtes-vous sûr de vouloir supprimer cette marque ?</p>

<dl class="row">
    <dt class="col-sm-3">Marque</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Pays</dt>
    <dd class="col-sm-9">@Model.Country</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Supprimer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>